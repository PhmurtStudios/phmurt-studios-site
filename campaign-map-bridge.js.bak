(function(global) {
  'use strict';

  // ============================================================================
  // SEEDED RNG - same as campaign-world.js (mulberry32)
  // ============================================================================
  function mulberry32(a) {
    return function() {
      a |= 0;
      a = (a + 0x6d2b79f5) | 0;
      let t = Math.imul(a ^ (a >>> 15), 1 | a);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

